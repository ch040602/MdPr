{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdpresent.dev/schemas/presentation-ir.schema.json",
  "title": "Presentation IR",
  "type": "object",
  "required": [
    "version",
    "meta",
    "outline",
    "slides",
    "coherenceGroups",
    "assets",
    "diagnostics"
  ],
  "properties": {
    "version": {
      "const": "1.0"
    },
    "meta": {
      "type": "object",
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "sourcePath": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "outline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outlineNode"
      }
    },
    "slides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slide"
      }
    },
    "coherenceGroups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coherenceGroup"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "outlineNode": {
      "type": "object",
      "required": [
        "id",
        "level",
        "title",
        "blocks",
        "headingPath",
        "children"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "title": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        },
        "headingPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outlineNode"
          }
        }
      },
      "additionalProperties": false
    },
    "slide": {
      "type": "object",
      "required": [
        "id",
        "index",
        "role",
        "headingPath",
        "source",
        "blocks",
        "intent",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "role": {
          "enum": [
            "cover",
            "toc",
            "section",
            "content",
            "appendix"
          ]
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "headingPath": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        },
        "intent": {
          "enum": [
            "title",
            "standard",
            "comparison",
            "evidence",
            "metric",
            "list",
            "grid",
            "timeline",
            "workflow",
            "table",
            "image",
            "code",
            "quote",
            "summary",
            "diagram",
            "chart"
          ]
        },
        "intentScores": {
          "type": "object",
          "properties": {
            "comparison": { "type": "number" },
            "evidence": { "type": "number" },
            "metric": { "type": "number" },
            "chart": { "type": "number" },
            "table": { "type": "number" },
            "image": { "type": "number" },
            "workflow": { "type": "number" },
            "timeline": { "type": "number" },
            "code": { "type": "number" },
            "summary": { "type": "number" }
          },
          "additionalProperties": false
        },
        "secondaryIntents": {
          "type": "array",
          "items": {
            "enum": [
              "title",
              "standard",
              "comparison",
              "evidence",
              "metric",
              "list",
              "grid",
              "timeline",
              "workflow",
              "table",
              "image",
              "code",
              "quote",
              "summary",
              "diagram",
              "chart"
            ]
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryItemCount": {
          "type": "integer",
          "minimum": 0
        },
        "density": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "block": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "heading",
            "paragraph",
            "bulletList",
            "listItem",
            "table",
            "image",
            "code",
            "quote",
            "html",
            "slideBreak",
            "diagram",
            "chart"
          ]
        },
        "text": {
          "type": "string"
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lineIndents": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "sentences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inlineRuns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inlineRun"
          }
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "listItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/listItem"
          }
        },
        "listKind": {
          "enum": [
            "ordered",
            "unordered",
            "mixed"
          ]
        },
        "diagram": {
          "$ref": "#/$defs/diagram"
        },
        "chart": {
          "$ref": "#/$defs/chart"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "src": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        }
      },
      "additionalProperties": true
    },
    "coherenceGroup": {
      "type": "object",
      "required": [
        "id",
        "slideId",
        "headingPath",
        "primaryBlockId",
        "supportingBlockIds",
        "role",
        "keepTogether",
        "splitPriority"
      ],
      "properties": {
        "id": { "type": "string" },
        "slideId": { "type": "string" },
        "headingPath": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primaryBlockId": { "type": "string" },
        "supportingBlockIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "role": {
          "enum": [
            "argument",
            "comparison",
            "workflow",
            "evidence-pack",
            "summary"
          ]
        },
        "keepTogether": { "type": "boolean" },
        "splitPriority": {
          "type": "integer",
          "minimum": 0
        },
        "blockRoles": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "claim",
              "evidence",
              "metric",
              "example",
              "risk",
              "decision",
              "action",
              "caption",
              "source",
              "appendix"
            ]
          }
        },
        "semanticSignals": {
          "type": "array",
          "items": {
            "enum": [
              "claim",
              "evidence",
              "metric",
              "example",
              "risk",
              "decision",
              "action",
              "caption",
              "source",
              "appendix"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "inlineRun": {
      "type": "object",
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "bold": {
          "type": "boolean"
        },
        "italic": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "listItem": {
      "type": "object",
      "required": [
        "text",
        "level",
        "ordered"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 0
        },
        "ordered": {
          "type": "boolean"
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "marker": {
          "type": "string"
        },
        "runs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inlineRun"
          }
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "descriptionRuns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inlineRun"
          }
        }
      },
      "additionalProperties": false
    },
    "diagram": {
      "type": "object",
      "required": [
        "kind",
        "nodes",
        "edges"
      ],
      "properties": {
        "kind": {
          "const": "pipeline"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "to"
            ],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "chart": {
      "type": "object",
      "required": [
        "kind",
        "labels",
        "series"
      ],
      "properties": {
        "kind": {
          "enum": [
            "bar",
            "arc-ring",
            "gauge",
            "connected-strip",
            "ranked-bars",
            "metric-dots"
          ]
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "series": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "values"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "number"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "required": [
        "id",
        "type",
        "path"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "image",
            "font",
            "template",
            "other"
          ]
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sourceRange": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": [
        "level",
        "message"
      ],
      "properties": {
        "level": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "slideId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
