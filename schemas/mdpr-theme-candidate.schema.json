{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdpresent.dev/schemas/mdpr-theme-candidate.schema.json",
  "title": "MDPR Theme Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "tokens", "styleSystem", "registration", "constraints", "rationale", "requiresApproval"],
  "properties": {
    "schemaVersion": { "const": "mdpr-theme-candidate-v1" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sourceSha256", "generatedBy", "generatedAt"],
      "properties": {
        "kind": { "const": "design-md" },
        "path": { "type": "string", "minLength": 1 },
        "sourceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "generatedBy": { "const": "mdpr-skill" },
        "generatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colors", "typography", "spacing", "shape"],
      "properties": {
        "colors": { "type": "object", "additionalProperties": { "type": "string" } },
        "typography": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": ["string", "number"] }
          }
        },
        "spacing": { "type": "object", "additionalProperties": { "type": "number" } },
        "shape": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    },
    "styleSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bestFor", "layoutIntents", "layoutBlueprints", "decorationFamilies"],
      "properties": {
        "bestFor": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "layoutIntents": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "layoutBlueprints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "intent", "description", "regions"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "intent": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "regions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            }
          }
        },
        "decorationFamilies": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "registration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets", "workflow"],
      "properties": {
        "targets": {
          "type": "array",
          "items": {
            "enum": ["mdpr-theme-pack", "mdpr-profile", "mdpr-rulebook", "deck-local-style-pack"]
          }
        },
        "workflow": { "const": "proposal-review-approve-mdpr-import" }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mdprOwnsFinalLayout", "mdprOwnsFinalThemeBinding", "noRawUseInAgentHints", "requiresDesignLockUpdate"],
      "properties": {
        "mdprOwnsFinalLayout": { "const": true },
        "mdprOwnsFinalThemeBinding": { "const": true },
        "noRawUseInAgentHints": { "const": true },
        "requiresDesignLockUpdate": { "const": true }
      }
    },
    "rationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dosDonts"],
      "properties": {
        "overview": { "type": "string" },
        "layout": { "type": "string" },
        "dosDonts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "requiresApproval": { "const": true }
  }
}
