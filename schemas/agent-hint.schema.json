{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdpresent.dev/schemas/agent-hint.schema.json",
  "title": "MDPR Agent Hint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceSha256", "hints"],
  "properties": {
    "schemaVersion": {
      "const": "mdpr-agent-hint-v1"
    },
    "sourceSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "mdprVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "generatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "hints": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slideId", "confidence"],
        "properties": {
          "slideId": {
            "type": "string",
            "minLength": 1
          },
          "workflowIntentCandidate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["intent", "confidence", "evidenceRefs"],
            "properties": {
              "intent": {
                "enum": ["template-fill", "style-transform", "theme-import", "generated-asset-request"]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "evidenceRefs": {
                "type": "array",
                "maxItems": 24,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                }
              }
            }
          },
          "intentCandidate": {
            "enum": [
              "title",
              "standard",
              "comparison",
              "evidence",
              "metric",
              "list",
              "grid",
              "timeline",
              "workflow",
              "table",
              "image",
              "code",
              "quote",
              "summary",
              "diagram",
              "chart"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "groupCandidates": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["elementIds", "role", "confidence"],
              "properties": {
                "elementIds": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 40,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "role": {
                  "enum": [
                    "claim",
                    "evidence",
                    "metric",
                    "example",
                    "risk",
                    "decision",
                    "action",
                    "caption",
                    "source",
                    "appendix",
                    "argument",
                    "comparison",
                    "workflow",
                    "evidence-pack",
                    "summary"
                  ]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "importanceCandidates": {
            "type": "array",
            "maxItems": 80,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["elementId", "importance", "confidence"],
              "properties": {
                "elementId": {
                  "type": "string",
                  "minLength": 1
                },
                "importance": {
                  "enum": ["primary", "secondary", "supporting"]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "keyMessageCandidates": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["messageRole", "emphasisLevel", "elementIds", "reason", "confidence"],
              "properties": {
                "messageRole": {
                  "enum": ["main-takeaway", "decision-needed", "risk-callout", "proof-anchor", "section-transition"]
                },
                "emphasisLevel": {
                  "enum": ["primary", "secondary", "supporting"]
                },
                "elementIds": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 20,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "evidenceRefs": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 20,
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 160
                  }
                },
                "claimRef": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                },
                "preferredPlaceholderRole": {
                  "enum": ["title", "subtitle", "body", "callout", "caption"]
                },
                "reason": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "contentSplitCandidates": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["reason", "elementIds", "preferredSplitBy", "confidence"],
              "properties": {
                "reason": {
                  "enum": ["dense-content", "mixed-topics", "long-bullets", "evidence-overload"]
                },
                "elementIds": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 40,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "preferredSplitBy": {
                  "enum": ["h2", "h3", "h4", "block-group", "list-chunk"]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "readabilityCandidates": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "elementIds", "reason", "confidence"],
              "properties": {
                "action": {
                  "enum": ["shorten-copy", "plain-language", "reduce-bullet-count", "claim-title", "move-detail-to-notes"]
                },
                "elementIds": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 40,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "reason": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "templateUseCandidate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["templateSourceRef", "masterSlidePolicy", "placeholderPolicy", "confidence"],
            "properties": {
              "templateSourceRef": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              },
              "masterSlidePolicy": {
                "enum": ["preserve-existing-master-slides", "use-master-as-theme-source"]
              },
              "placeholderPolicy": {
                "enum": ["prefer-existing-placeholders", "fill-named-slots-only"]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "mediaPolicyCandidate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["imageUse", "imageSearch", "iconUse", "evidenceRefs"],
            "properties": {
              "imageUse": {
                "enum": ["no-image", "source-image-only", "generated-asset-approved"]
              },
              "imageSearch": {
                "enum": ["disabled", "source-evidence-only", "explicit-request-only"]
              },
              "iconUse": {
                "enum": ["no-new-icons", "semantic-keywords-only"]
              },
              "evidenceRefs": {
                "type": "array",
                "maxItems": 24,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                }
              }
            }
          },
          "iconKeywordCandidates": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["keyword", "elementIds", "evidenceRefs", "reason", "confidence"],
              "properties": {
                "keyword": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 48,
                  "pattern": "^[A-Za-z0-9 _.-]+$"
                },
                "elementIds": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 20,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "evidenceRefs": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 20,
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 160
                  }
                },
                "reason": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "workflowIntentRef": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                }
              }
            }
          },
          "visualAssetCandidates": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "trigger", "requestRef", "semanticPrompt", "confidence"],
              "properties": {
                "kind": {
                  "enum": ["generated-image"]
                },
                "trigger": {
                  "enum": ["explicit-generated-asset-request"]
                },
                "requestRef": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                },
                "semanticPrompt": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "rationale": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    }
  }
}
