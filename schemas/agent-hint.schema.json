{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdpresent.dev/schemas/agent-hint.schema.json",
  "title": "MDPR Agent Hint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceSha256", "hints"],
  "properties": {
    "schemaVersion": {
      "const": "mdpr-agent-hint-v1"
    },
    "sourceSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "mdprVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "generatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "hints": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slideId", "confidence"],
        "properties": {
          "slideId": {
            "type": "string",
            "minLength": 1
          },
          "intentCandidate": {
            "enum": [
              "title",
              "standard",
              "comparison",
              "evidence",
              "metric",
              "list",
              "grid",
              "timeline",
              "workflow",
              "table",
              "image",
              "code",
              "quote",
              "summary",
              "diagram",
              "chart"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "groupCandidates": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["elementIds", "role", "confidence"],
              "properties": {
                "elementIds": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 40,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "role": {
                  "enum": [
                    "claim",
                    "evidence",
                    "metric",
                    "example",
                    "risk",
                    "decision",
                    "action",
                    "caption",
                    "source",
                    "appendix",
                    "argument",
                    "comparison",
                    "workflow",
                    "evidence-pack",
                    "summary"
                  ]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "importanceCandidates": {
            "type": "array",
            "maxItems": 80,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["elementId", "importance", "confidence"],
              "properties": {
                "elementId": {
                  "type": "string",
                  "minLength": 1
                },
                "importance": {
                  "enum": ["primary", "secondary", "supporting"]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "iconKeywordCandidates": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 48,
              "pattern": "^[A-Za-z0-9 _.-]+$"
            }
          },
          "rationale": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    }
  }
}
