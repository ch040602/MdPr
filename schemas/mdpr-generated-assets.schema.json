{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdpr.dev/schemas/mdpr-generated-assets.schema.json",
  "title": "MDPR generated asset provenance and request policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedBy", "assets"],
  "properties": {
    "schemaVersion": { "const": "mdpr-generated-assets-v1" },
    "generatedBy": { "type": "string" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetId", "kind", "purpose", "provider", "request", "boundary"],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "kind": { "const": "generated-image" },
        "purpose": {
          "enum": ["primary-visual", "diagram-visual", "texture", "background-fragment", "icon-replacement", "reference-composite"]
        },
        "provider": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "model", "promptHash"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "baseUrl": { "type": "string" },
            "promptHash": { "$ref": "#/$defs/hash" },
            "sourceInputHashes": {
              "type": "array",
              "items": { "$ref": "#/$defs/hash" }
            },
            "supportsTransparency": { "type": "boolean" },
            "supportedQualities": {
              "type": "array",
              "items": { "enum": ["low", "medium", "standard", "high", "hd"] }
            }
          }
        },
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size", "quality", "background", "transparency"],
          "properties": {
            "size": { "type": "string", "pattern": "^[1-9][0-9]{1,4}x[1-9][0-9]{1,4}$" },
            "quality": { "enum": ["low", "medium", "standard", "high", "hd"] },
            "background": { "enum": ["auto", "opaque", "transparent"] },
            "transparency": { "enum": ["not-needed", "preferred", "required", "forbidden"] },
            "fullSlide": { "const": false }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "mimeType": { "enum": ["image/png", "image/jpeg", "image/webp"] }
          }
        },
        "boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mdprOwnsPlacement", "notFullSlideRenderer", "noSecrets"],
          "properties": {
            "mdprOwnsPlacement": { "const": true },
            "notFullSlideRenderer": { "const": true },
            "noSecrets": { "const": true }
          }
        }
      }
    }
  }
}
