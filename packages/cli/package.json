{
  "name": "@mdpresent/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mdpresent": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-schemas.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@mdpresent/core": "workspace:*",
    "@mdpresent/layout": "workspace:*",
    "@mdpresent/override": "workspace:*",
    "@mdpresent/render-html": "workspace:*",
    "@mdpresent/render-pdf": "workspace:*",
    "@mdpresent/render-pptx": "workspace:*",
    "ajv": "^8.20.0",
    "yaml": "*"
  }
}
